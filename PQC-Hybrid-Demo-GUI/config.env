# ══════════════════════════════════════════════════════════════
# PQC Demo — Global Configuration
#
# Single source of truth for all IPs, ports, and paths.
# Sourced by run.sh, read by Python GUI, and compiled into C.
# ══════════════════════════════════════════════════════════════

# Host (WSL) — where the server + GUI run
SERVER_IP=192.168.0.100

# S4SK Board — where the client runs
BOARD_IP=192.168.0.5
BOARD_USER=root
BOARD_CLIENT_PATH=/home/root/PQC-DEMO-Chandru/shared/bin/client

# Ports
PQC_PORT=9090          # server <-> client crypto exchange
GUI_PORT=8081          # server -> GUI JSON event reporting

# Paths (relative to project root)
SERVER_BIN=./server
LOCAL_CLIENT=              # set empty to use SSH to board instead
